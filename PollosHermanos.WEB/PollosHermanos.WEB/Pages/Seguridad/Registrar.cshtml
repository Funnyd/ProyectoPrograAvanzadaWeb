@page
@model PollosHermanos.WEB.Pages.Seguridad.RegistrarModel
@{
}

<head>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-6">
                <div class="card">
                    <div class="card-body p-3">
                        <div class="text-center mb-4">
                            <h3 class="fw-normal">Registro</h3>
                        </div>

                        <form method="post">
                            <h5 class="mb-3">Datos</h5>
                            <div class="mb-3">
                                <label class="form-label">Nombre completo</label>
                                <input type="text" class="form-control" asp-for="cliente.Nombre" >
                                <span asp-validation-for="cliente.Nombre" class="text-danger small"></span>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Correo electronico</label>
                                <input type="email" class="form-control" asp-for="usuario.Correo" 
                                       placeholder="Ejem: ejemplo@correo.com">
                                <span asp-validation-for="usuario.Correo" class="text-danger small"></span>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Contraseña</label>
                                <input type="password" class="form-control" asp-for="usuario.Password" >
                                <span asp-validation-for="usuario.Password" class="text-danger small"></span>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Dirección</label>
                                <input type="text" class="form-control" asp-for="cliente.Direccion" >
                                <span asp-validation-for="cliente.Direccion" class="text-danger small"></span>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Metodo de pago preferido</label>
                                <select class="form-select" asp-for="cliente.MetodoPago">
                                    <option value="">Seleccione...</option>
                                    <option value="Efectivo">Efectivo</option>
                                    <option value="Tarjeta">Tarjeta/débito</option>
                                    <option value="Sinpe">Sinpe</option>
                                </select>
                                <span asp-validation-for="cliente.MetodoPago" class="text-danger small"></span>
                            </div>
                            <button type="submit" class="btn btn-primary w-100 mt-3">Registrar</button>
                        </form>

                        <hr class="my-4">

                        <div class="text-center small">
                            <a href="./login" class="text-decoration-none">
                                Ya tienes una cuenta?
                            </a>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>

</body>